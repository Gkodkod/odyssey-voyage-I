{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "target": "ES2020",
    "module": "Node16",
    "moduleResolution": "Node16",
    "resolveJsonModule": true,
    "noImplicitAny": false,
    "skipLibCheck": true
  },
  "include": [
    "subgraph-locations/**/*.js",
    "subgraph-reviews/**/*.js"
  ],
  "exclude": [
    "node_modules",
    "client",
    "final"
  ]
}
